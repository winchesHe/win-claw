{
  "name": "@winches/storage",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/migrations',{recursive:true});cpSync('src/migrations','dist/migrations',{recursive:true})\"",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "test": "vitest --run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@winches/ai": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "sqlite-vec": "^0.1.7",
    "pino": "^9.7.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "fast-check": "^3.23.2",
    "vitest": "^3.2.1"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
