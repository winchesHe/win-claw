    "@winches/storage": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "fast-check": "^3.23.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
