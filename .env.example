# =============================================================================
# LLM 配置
# =============================================================================

# LLM API Key（OpenAI / Anthropic / Google / OpenAI-compatible 通用）
AGENT_API_KEY=your_api_key_here

# LLM Provider 覆盖（可选，优先级高于 config.yaml）
# 可选值：openai | anthropic | google | openai-compatible
AGENT_LLM_PROVIDER=openai

# LLM 模型覆盖（可选）
AGENT_LLM_MODEL=gpt-4o

# LLM Base URL（可选，openai-compatible provider 时使用）
AGENT_LLM_BASE_URL=https://your-custom-endpoint/v1

# =============================================================================
# Telegram Bot 配置
# =============================================================================

AGENT_TELEGRAM_TOKEN=your_telegram_bot_token_here

# =============================================================================
# 存储配置
# =============================================================================

# SQLite 数据库路径（可选，默认 ./data/agent.db）
AGENT_STORAGE_DB_PATH=./data/agent.db
